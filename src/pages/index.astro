---
import Table from '../components/Table';
import { getModelIdsAndNames } from '../sqlEngine';
import { data } from "./data.json";
import MainLayout from '../layouts/MainLayout.astro';

// Get the models for the server-side
const models = getModelIdsAndNames(data);
---

<MainLayout>
    <Table idsAndNames={models} vendors={data.vendors} client:load />
</MainLayout>
